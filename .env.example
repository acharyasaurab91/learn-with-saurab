NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/learn-with-saurab
SESSION_SECRET=your-64-character-random-string-here

# Email (Gmail SMTP — use App Password, not your real password)
EMAIL_USER=contactsaurabsir@gmail.com
EMAIL_PASS=your-gmail-app-password-here
EMAIL_HOST=smtp.gmail.com

# eSewa Payment (get from eSewa merchant dashboard)
# Test merchant code: EPAYTEST
# Live: get from merchant.esewa.com.np
ESEWA_MERCHANT_CODE=EPAYTEST

# Khalti Payment (get from Khalti merchant dashboard)
# Test: use test_secret_key_c9f20e5e87d74b8f9fdbb0fcbdac0f31 (hardcoded in code as fallback)
# Live: get from khalti.com/dashboard → Settings → Live Keys
KHALTI_SECRET_KEY=your-khalti-secret-key-here

# Base URL (used for payment callbacks — must be your live domain in production)
BASE_URL=https://learnwithsaurab.com.np

# Admin setup
ADMIN_SECRET_CODE=your-secret-admin-code
