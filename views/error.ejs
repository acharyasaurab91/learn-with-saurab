<%- include('partials/header') %>
<div class="error-page container">
  <div class="error-content">
    <div class="error-icon"><i class="fas fa-exclamation-circle"></i></div>
    <h1><%= title || 'Error' %></h1>
    <p><%= message || 'Something went wrong.' %></p>
    <div class="error-cta">
      <a href="/" class="btn-hero-primary"><i class="fas fa-home"></i> Go Home</a>
      <a href="javascript:history.back()" class="btn-hero-outline"><i class="fas fa-arrow-left"></i> Go Back</a>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
