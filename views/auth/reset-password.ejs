<%- include('../partials/header') %>
<div class="auth-page">
  <div class="auth-bg"><div class="auth-orb auth-orb-1"></div><div class="auth-orb auth-orb-2"></div></div>
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-header">
        <a href="/" class="auth-logo"><i class="fas fa-graduation-cap"></i><span>Learn With Saurab</span></a>
        <h1>Set New Password</h1>
        <p>Choose a strong password for your account</p>
      </div>
      <% if (error) { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>
      <form action="/reset-password/<%= token %>" method="POST" class="auth-form">
        <div class="form-group">
          <label><i class="fas fa-lock"></i> New Password</label>
          <input type="password" name="password" placeholder="Min 8 characters" required minlength="8">
        </div>
        <div class="form-group">
          <label><i class="fas fa-lock"></i> Confirm Password</label>
          <input type="password" name="confirmPassword" placeholder="Repeat password" required>
        </div>
        <button type="submit" class="btn-auth"><span>Reset Password</span><i class="fas fa-key"></i></button>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
