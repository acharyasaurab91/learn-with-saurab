<%- include('partials/header') %>

<div class="container" style="min-height:70vh;display:flex;align-items:center;justify-content:center;padding:60px 20px">
  <div style="text-align:center;max-width:480px">
    <div style="width:80px;height:80px;background:rgba(239,68,68,0.12);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;border:2px solid rgba(239,68,68,0.25)">
      <i class="fas fa-times" style="font-size:32px;color:#EF4444"></i>
    </div>
    <h1 style="font-family:'Montserrat',sans-serif;font-size:28px;font-weight:900;color:#F9FAFB;margin-bottom:12px">Payment Failed</h1>
    <p style="color:#9CA3AF;font-size:15px;line-height:1.6;margin-bottom:8px">
      Your <strong style="color:#F9FAFB"><%= method === 'khalti' ? 'Khalti' : 'eSewa' %></strong> payment was not completed successfully.
    </p>
    <p style="color:#6B7280;font-size:14px;margin-bottom:32px">
      No money has been deducted from your account. You can try again or use a different payment method.
    </p>
    <div style="display:flex;flex-direction:column;gap:12px;align-items:center">
      <a href="javascript:history.back()" style="display:inline-flex;align-items:center;gap:8px;padding:12px 28px;background:linear-gradient(135deg,#00D4FF,#7C3AED);color:#fff;border-radius:10px;text-decoration:none;font-weight:700;font-size:14px">
        <i class="fas fa-redo"></i> Try Again
      </a>
      <a href="/browse-courses" style="color:#6B7280;font-size:13px;text-decoration:none;display:flex;align-items:center;gap:6px">
        <i class="fas fa-arrow-left"></i> Browse other courses
      </a>
    </div>
    <div style="margin-top:32px;padding:16px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.06);border-radius:10px;font-size:13px;color:#6B7280">
      <i class="fas fa-headset" style="color:#00D4FF;margin-right:6px"></i>
      Need help? Contact us at <a href="mailto:contactsaurabsir@gmail.com" style="color:#00D4FF">contactsaurabsir@gmail.com</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
