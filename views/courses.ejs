<%- include('partials/header') %>

<div class="page-hero page-hero-sm">
  <div class="container">
    <h1>Browse <span class="gradient-text">Courses</span></h1>
    <p>Find the perfect course for your exam preparation</p>
  </div>
</div>

<div class="courses-page container">
  <div class="courses-filters">
    <form method="GET" action="/browse-courses" id="filterForm">
      <div class="filter-bar">
        <div class="search-wrap">
          <i class="fas fa-search"></i>
          <input type="text" name="search" placeholder="Search courses..." value="<%= query.search || '' %>">
        </div>
        <select name="category" onchange="this.form.submit()">
          <option value="">All Categories</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.slug %>" <%= query.category === cat.slug ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
        <select name="level" onchange="this.form.submit()">
          <option value="">All Levels</option>
          <option value="Beginner" <%= query.level === 'Beginner' ? 'selected' : '' %>>Beginner</option>
          <option value="Intermediate" <%= query.level === 'Intermediate' ? 'selected' : '' %>>Intermediate</option>
          <option value="Advanced" <%= query.level === 'Advanced' ? 'selected' : '' %>>Advanced</option>
        </select>
        <button type="submit" class="btn-filter"><i class="fas fa-filter"></i> Filter</button>
        <a href="/browse-courses" class="btn-clear">Clear</a>
      </div>
    </form>
  </div>

  <div class="courses-results">
    <p class="results-count"><%= courses.length %> course<%= courses.length !== 1 ? 's' : '' %> found</p>
    <% if (courses.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-search"></i>
        <h3>No courses found</h3>
        <p>Try adjusting your filters or <a href="/browse-courses">view all courses</a></p>
      </div>
    <% } else { %>
    <div class="courses-grid courses-grid-wide">
      <% courses.forEach((course, i) => { %>
      <div class="course-card" data-gsap="fade-up" data-delay="<%= (i % 4) * 0.1 %>">
        <div class="course-img-wrap">
          <% if (course.imageUrl) { %>
            <img src="<%= course.imageUrl %>" alt="<%= course.title %>" loading="lazy">
          <% } else { %>
            <div class="course-img-placeholder"><i class="fas fa-book-open"></i></div>
          <% } %>
          <div class="course-badge"><%= course.category || 'Course' %></div>
          <% if (course.isFeatured) { %><div class="course-featured-badge"><i class="fas fa-star"></i> Featured</div><% } %>
        </div>
        <div class="course-body">
          <h3 class="course-title"><%= course.title %></h3>
          <p class="course-desc"><%= course.description.substring(0, 90) %>...</p>
          <div class="course-meta">
            <span><i class="fas fa-layer-group"></i> <%= course.level %></span>
            <span><i class="fas fa-users"></i> <%= course.enrolledCount || 0 %></span>
            <% if (course.duration) { %><span><i class="fas fa-clock"></i> <%= course.duration %>h</span><% } %>
          </div>
          <div class="course-footer">
            <div class="course-price">
              <% if (course.price === 0) { %>
                <span class="price-free">FREE</span>
              <% } else { %>
                <span class="price-amount">Rs. <%= course.price.toLocaleString() %></span>
              <% } %>
            </div>
            <a href="/courses/<%= course._id %>" class="btn-enroll">
              <span>View</span><i class="fas fa-arrow-right"></i>
            </a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
