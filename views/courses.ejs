<%- include('partials/header') %>

<div class="page-hero page-hero-sm">
  <div class="container">
    <h1>Browse <span class="gradient-text">Courses</span></h1>
    <p>Find the perfect course for your exam preparation</p>
  </div>
</div>

<div class="courses-page container">
  <div class="courses-filters">
    <form method="GET" action="/browse-courses" id="filterForm">
      <div class="filter-bar">
        <div class="search-wrap">
          <i class="fas fa-search"></i>
          <input type="text" name="search" placeholder="Search courses..." value="<%= query.search || '' %>">
        </div>
        <select name="category" onchange="this.form.submit()">
          <option value="">All Categories</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.slug %>" <%= query.category === cat.slug ? 'selected' : '' %>><%= cat.name %></option>
          <% }) %>
        </select>
        <select name="examType" onchange="this.form.submit()">
          <option value="">All Exam Types</option>
          <option value="CEE - Medical & Paramedical" <%= query.examType === 'CEE - Medical & Paramedical' ? 'selected' : '' %>>CEE (Medical & Paramedical)</option>
          <option value="CEE - BNS (B.N.Sc.)" <%= query.examType === 'CEE - BNS (B.N.Sc.)' ? 'selected' : '' %>>CEE (BNS)</option>
          <option value="IOE - Engineering" <%= query.examType === 'IOE - Engineering' ? 'selected' : '' %>>IOE</option>
          <option value="Loksewa / लोकसेवा" <%= query.examType === 'Loksewa / लोकसेवा' ? 'selected' : '' %>>Loksewa</option>
          <option value="Nursing License (NLEN)" <%= query.examType === 'Nursing License (NLEN)' ? 'selected' : '' %>>Nursing License</option>
          <option value="CMLT License" <%= query.examType === 'CMLT License' ? 'selected' : '' %>>CMLT License</option>
          <option value="Pharmacy License" <%= query.examType === 'Pharmacy License' ? 'selected' : '' %>>Pharmacy License</option>
          <option value="HA License" <%= query.examType === 'HA License' ? 'selected' : '' %>>HA License</option>
          <option value="SEE (Grade 10)" <%= query.examType === 'SEE (Grade 10)' ? 'selected' : '' %>>SEE (Grade 10)</option>
          <option value="Grade 11" <%= query.examType === 'Grade 11' ? 'selected' : '' %>>Grade 11</option>
          <option value="Grade 12" <%= query.examType === 'Grade 12' ? 'selected' : '' %>>Grade 12</option>
        </select>
        <button type="submit" class="btn-filter"><i class="fas fa-filter"></i> Filter</button>
        <a href="/browse-courses" class="btn-clear">Clear</a>
      </div>
    </form>
  </div>

  <div class="courses-results">
    <p class="results-count"><%= courses.length %> course<%= courses.length !== 1 ? 's' : '' %> found</p>
    <% if (courses.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-search"></i>
        <h3>No courses found</h3>
        <p>Try adjusting your filters or <a href="/browse-courses">view all courses</a></p>
      </div>
    <% } else { %>
    <div class="courses-grid courses-grid-wide">
      <% courses.forEach((course, i) => { %>
      <div class="course-card" data-gsap="fade-up" data-delay="<%= (i % 4) * 0.1 %>">
        <div class="course-img-wrap">
          <% if (course.imageUrl) { %>
            <img src="<%= course.imageUrl %>" alt="<%= course.title %>" loading="lazy">
          <% } else { %>
            <div class="course-img-placeholder"><i class="fas fa-book-open"></i></div>
          <% } %>
          <div class="course-badge"><%= course.category || 'Course' %></div>
          <% if (course.isFeatured) { %><div class="course-featured-badge"><i class="fas fa-star"></i> Featured</div><% } %>
        </div>
        <div class="course-body">
          <h3 class="course-title"><%= course.title %></h3>
          <p class="course-desc"><%= course.description.substring(0, 90) %>...</p>
          <div class="course-meta">
            <% if (course.examType) { %><span><i class="fas fa-layer-group"></i> <%= course.examType %></span><% } %>
            <span><i class="fas fa-users"></i> <%= course.enrolledCount || 0 %></span>
            <% if (course.duration) { %><span><i class="fas fa-clock"></i> <%= course.duration %>h</span><% } %>
          </div>
          <% if (course.targetPrograms && course.targetPrograms.length > 0) { %>
          <div class="course-meta" style="margin-top:-6px">
            <span style="color:#00D4FF"><i class="fas fa-tags"></i> <%= course.targetPrograms.join(', ') %></span>
          </div>
          <% } %>
          <% if (course.stream) { %>
          <div class="course-meta" style="margin-top:-6px">
            <span style="color:#F97316"><i class="fas fa-flask"></i> <%= course.stream %> Stream</span>
          </div>
          <% } %>
          <div class="course-footer">
            <div class="course-price">
              <% if (course.price === 0) { %>
                <span class="price-free">FREE</span>
              <% } else { %>
                <span class="price-amount">Rs. <%= course.price.toLocaleString() %></span>
              <% } %>
            </div>
            <a href="/courses/<%= course._id %>" class="btn-enroll">
              <span>View</span><i class="fas fa-arrow-right"></i>
            </a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
