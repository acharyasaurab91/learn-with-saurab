<%- include('../partials/header', { extraCss: '<link rel="stylesheet" href="/css/admin.css">' }) %>
<div class="admin-layout">
  <%- include('./partials/sidebar', { activePage: 'courses' }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <h1><i class="fas fa-<%= course ? 'edit' : 'plus-circle' %>"></i> <%= course ? 'Edit Course' : 'New Course' %></h1>
      <a href="/admin/courses" class="btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
    </div>
    <div class="admin-section">
      <form action="<%= course ? '/admin/courses/' + course._id : '/admin/courses' %>" method="POST" enctype="multipart/form-data" class="admin-form">
        <div class="form-row-2">
          <div class="form-group"><label>Course Title *</label><input type="text" name="title" value="<%= course ? course.title : '' %>" required placeholder="e.g. Complete CEE Physics"></div>
          <div class="form-group">
            <label>Category</label>
            <select name="category">
              <option value="">Select Category</option>
              <% categories.forEach(cat => { %><option value="<%= cat.slug %>" <%= course && course.category === cat.slug ? 'selected' : '' %>><%= cat.name %></option><% }) %>
            </select>
          </div>
        </div>
        <div class="form-group"><label>Description *</label><textarea name="description" rows="4" required><%= course ? course.description : '' %></textarea></div>
        <div class="form-row-3">
          <div class="form-group"><label>Price (Rs.)</label><input type="number" name="price" value="<%= course ? course.price : 0 %>" min="0"></div>
          <div class="form-group"><label>Subject</label><input type="text" name="subject" value="<%= course ? course.subject || '' : '' %>" placeholder="e.g. Physics"></div>
          <div class="form-group"><label>Level</label><select name="level"><option value="Beginner" <%= course && course.level === 'Beginner' ? 'selected' : '' %>>Beginner</option><option value="Intermediate" <%= course && course.level === 'Intermediate' ? 'selected' : '' %>>Intermediate</option><option value="Advanced" <%= course && course.level === 'Advanced' ? 'selected' : '' %>>Advanced</option></select></div>
        </div>
        <div class="form-group"><label>Course Thumbnail</label><input type="file" name="image" accept="image/*"></div>
        <% if (course && course.imageUrl) { %><div class="current-img"><img src="<%= course.imageUrl %>" alt="Current" style="max-height:120px;border-radius:8px"><span class="text-muted">Current thumbnail</span></div><% } %>
        <div class="form-row-2">
          <label class="checkbox-label"><input type="checkbox" name="isFeatured" <%= course && course.isFeatured ? 'checked' : '' %>> Featured Course</label>
          <label class="checkbox-label"><input type="checkbox" name="isPublished" <%= !course || course.isPublished ? 'checked' : '' %>> Published</label>
        </div>
        <div class="form-actions"><button type="submit" class="btn-admin-primary"><i class="fas fa-save"></i> <%= course ? 'Update Course' : 'Create Course' %></button></div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
