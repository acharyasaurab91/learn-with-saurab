<%- include('../partials/header', { extraCss: '<link rel="stylesheet" href="/css/admin.css">' }) %>
<div class="admin-layout">
  <%- include('./partials/sidebar', { activePage: 'reviews' }) %>
  <div class="admin-main">
    <div class="admin-topbar">
      <h1><i class="fas fa-star"></i> Reviews</h1>
      <span class="badge-green"><%= overallAvg.toFixed(1) %> ★ avg across <%= totalReviews %> review<%= totalReviews !== 1 ? 's' : '' %></span>
    </div>

    <div class="admin-section">
      <form method="GET" action="/admin/reviews" class="filter-bar" style="margin-bottom:0">
        <select name="course" onchange="this.form.submit()">
          <option value="">All Courses</option>
          <% courses.forEach(c => { %>
            <option value="<%= c._id %>" <%= query.course === c._id.toString() ? 'selected' : '' %>><%= c.title %></option>
          <% }) %>
        </select>
        <select name="rating" onchange="this.form.submit()">
          <option value="">All Ratings</option>
          <% [5,4,3,2,1].forEach(r => { %>
            <option value="<%= r %>" <%= query.rating == r ? 'selected' : '' %>><%= r %> Star<%= r !== 1 ? 's' : '' %></option>
          <% }) %>
        </select>
        <a href="/admin/reviews" class="btn-clear">Clear</a>
      </form>
    </div>

    <div class="admin-section">
      <table class="data-table">
        <thead><tr><th>Student</th><th>Course</th><th>Rating</th><th>Comment</th><th>Date</th><th>Actions</th></tr></thead>
        <tbody>
          <% if (reviews.length === 0) { %>
          <tr><td colspan="6" style="text-align:center;color:#9CA3AF;padding:24px">No reviews found.</td></tr>
          <% } %>
          <% reviews.forEach(r => { %>
          <tr>
            <td><%= r.userId ? r.userId.firstName + ' ' + (r.userId.lastName||'') : 'Deleted User' %><br><span class="text-muted text-sm"><%= r.userId ? r.userId.email : '' %></span></td>
            <td><%= r.courseId ? r.courseId.title : 'Deleted Course' %></td>
            <td>
              <span style="color:#F59E0B;white-space:nowrap">
                <% for (let s = 1; s <= 5; s++) { %><i class="fas fa-star" style="<%= s > r.rating ? 'opacity:0.2' : '' %>"></i><% } %>
              </span>
            </td>
            <td style="max-width:320px">
              <%= r.comment || '—' %>
              <% if (r.adminReply) { %>
                <div class="admin-reply-box">
                  <span class="admin-reply-label"><i class="fas fa-reply"></i> Your reply:</span>
                  <p class="admin-reply-text"><%= r.adminReply %></p>
                </div>
              <% } %>
            </td>
            <td><%= new Date(r.createdAt).toLocaleDateString() %></td>
            <td>
              <button onclick="openReplyModal('<%= r._id %>', <%- JSON.stringify(r.adminReply || '') %>)" class="btn-icon btn-blue" title="<%= r.adminReply ? 'Edit Reply' : 'Reply' %>"><i class="fas fa-reply"></i></button>
              <% if (r.adminReply) { %>
              <button onclick="deleteReply('<%= r._id %>')" class="btn-icon btn-red" title="Remove Reply"><i class="fas fa-comment-slash"></i></button>
              <% } %>
              <button onclick="deleteReview('<%= r._id %>')" class="btn-icon btn-red" title="Delete Review"><i class="fas fa-trash"></i></button>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div id="replyModal" class="reply-modal-overlay" style="display:none">
  <div class="reply-modal">
    <h3><i class="fas fa-reply"></i> Reply to Review</h3>
    <textarea id="replyTextarea" rows="5" placeholder="Write your response to this student..." maxlength="1000"></textarea>
    <div class="reply-modal-actions">
      <button type="button" class="btn-clear" onclick="closeReplyModal()">Cancel</button>
      <button type="button" class="btn btn-primary" onclick="submitReply()">Post Reply</button>
    </div>
  </div>
</div>

<%- include('../partials/footer', { extraJs: `<script>
async function deleteReview(id) {
  if (!confirm('Delete this review? This cannot be undone.')) return;
  const res = await fetch('/admin/reviews/' + id, { method: 'DELETE' });
  if ((await res.json()).success) location.reload();
  else alert('Could not delete review.');
}

let currentReplyReviewId = null;

function openReplyModal(id, existingReply) {
  currentReplyReviewId = id;
  document.getElementById('replyTextarea').value = existingReply || '';
  document.getElementById('replyModal').style.display = 'flex';
}

function closeReplyModal() {
  document.getElementById('replyModal').style.display = 'none';
  currentReplyReviewId = null;
}

async function submitReply() {
  const reply = document.getElementById('replyTextarea').value.trim();
  if (!reply) { alert('Please write a reply.'); return; }
  const res = await fetch('/admin/reviews/' + currentReplyReviewId + '/reply', {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ reply })
  });
  const data = await res.json();
  if (data.success) location.reload();
  else alert(data.message || 'Could not post reply.');
}

async function deleteReply(id) {
  if (!confirm('Remove your reply from this review?')) return;
  const res = await fetch('/admin/reviews/' + id + '/reply', { method: 'DELETE' });
  if ((await res.json()).success) location.reload();
  else alert('Could not remove reply.');
}
</script>` }) %>
