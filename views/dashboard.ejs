<%- include('partials/header') %>

<div class="dashboard-page">
  <div class="dashboard-sidebar">
    <div class="sidebar-user">
      <div class="sidebar-avatar"><%= user.firstName[0] %><%= user.lastName[0] %></div>
      <div>
        <strong><%= user.firstName %> <%= user.lastName %></strong>
        <span><%= user.email %></span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <a href="/dashboard" class="sidebar-link active"><i class="fas fa-th-large"></i> Dashboard</a>
      <a href="/my-courses" class="sidebar-link"><i class="fas fa-book-open"></i> My Courses</a>
      <a href="/my-tests" class="sidebar-link"><i class="fas fa-clipboard-list"></i> My Tests</a>
      <a href="/mistake-notebook" class="sidebar-link"><i class="fas fa-bolt"></i> Weakness Analyzer</a>
      <a href="/profile" class="sidebar-link"><i class="fas fa-user-cog"></i> Profile</a>
      <% if (user.isAdmin) { %><a href="/admin" class="sidebar-link admin-link"><i class="fas fa-shield-halved"></i> Admin Panel</a><% } %>
      <a href="/logout" class="sidebar-link logout-link"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </nav>
  </div>
  <div class="dashboard-main">
    <% if (welcome) { %>
    <div class="welcome-banner" id="welcomeBanner">
      <div>
        <h2>🎉 Welcome to Learn With Saurab, <%= user.firstName %>!</h2>
        <p>Your journey to exam success starts now. Browse courses or try a free test.</p>
      </div>
      <button onclick="document.getElementById('welcomeBanner').remove()"><i class="fas fa-times"></i></button>
    </div>
    <% } %>

    <div class="dashboard-header">
      <h1>Welcome back, <span class="gradient-text"><%= user.firstName %></span>! 👋</h1>
      <p>Here's your learning overview</p>
    </div>

    <div class="stats-grid">
      <div class="stat-card stat-card-1">
        <div class="stat-icon"><i class="fas fa-book-open"></i></div>
        <div class="stat-body">
          <div class="stat-number"><%= enrolledCourses.length %></div>
          <div class="stat-label">Enrolled Courses</div>
        </div>
      </div>
      <div class="stat-card stat-card-2">
        <div class="stat-icon"><i class="fas fa-clipboard-check"></i></div>
        <div class="stat-body">
          <div class="stat-number"><%= user.progress.testsTaken %></div>
          <div class="stat-label">Tests Taken</div>
        </div>
      </div>
      <div class="stat-card stat-card-3">
        <div class="stat-icon"><i class="fas fa-chart-bar"></i></div>
        <div class="stat-body">
          <div class="stat-number"><%= user.progress.avgScore %>%</div>
          <div class="stat-label">Avg Score</div>
        </div>
      </div>
      <div class="stat-card stat-card-4">
        <div class="stat-icon"><i class="fas fa-clock"></i></div>
        <div class="stat-body">
          <div class="stat-number"><%= user.progress.totalMinutesWatched %></div>
          <div class="stat-label">Minutes Watched</div>
        </div>
      </div>
    </div>

    <div class="dashboard-grid-2">
      <div class="dashboard-section">
        <div class="section-head">
          <h2><i class="fas fa-book-open"></i> My Courses</h2>
          <a href="/browse-courses" class="btn-sm">Browse More</a>
        </div>
        <% if (enrolledCourses.length === 0) { %>
          <div class="empty-state-sm">
            <i class="fas fa-book-open"></i>
            <p>No courses yet. <a href="/browse-courses">Find your first course!</a></p>
          </div>
        <% } else { %>
          <% enrolledCourses.slice(0, 3).forEach(course => { %>
          <div class="enrolled-course-row">
            <div class="enrolled-course-img">
              <% if (course.imageUrl) { %><img src="<%= course.imageUrl %>" alt="<%= course.title %>"><% } else { %><i class="fas fa-book"></i><% } %>
            </div>
            <div class="enrolled-course-info">
              <h4><%= course.title %></h4>
              <span class="badge-category"><%= course.category %></span>
              <div class="progress-bar-wrap">
                <div class="progress-bar-fill" style="width: 0%"></div>
              </div>
            </div>
            <a href="/courses/<%= course._id %>/learn" class="btn-sm-outline">Continue</a>
          </div>
          <% }) %>
          <% if (enrolledCourses.length > 3) { %>
            <a href="/my-courses" class="view-all-link">View all <%= enrolledCourses.length %> courses <i class="fas fa-arrow-right"></i></a>
          <% } %>
        <% } %>
      </div>

      <div class="dashboard-section">
        <div class="section-head">
          <h2><i class="fas fa-bolt text-yellow"></i> ⚡ Top Weaknesses</h2>
          <a href="/mistake-notebook" class="btn-sm">View All</a>
        </div>
        <% if (topMistakes.length === 0) { %>
          <div class="empty-state-sm">
            <i class="fas fa-trophy"></i>
            <p>No weak areas yet! Take a test to see your analysis.</p>
          </div>
        <% } else { %>
          <% topMistakes.forEach(m => { %>
          <div class="mistake-row">
            <div class="mistake-info">
              <p class="mistake-q"><%= m.questionText.substring(0, 70) %>...</p>
              <div class="mistake-meta">
                <span class="badge-topic"><%= m.topic || 'General' %></span>
                <span class="badge-times <%= m.timesMistaken >= 3 ? 'badge-critical' : '' %>">
                  <%= m.timesMistaken %>x wrong
                  <% if (m.timesMistaken >= 3) { %> 🔴 Critical<% } %>
                </span>
              </div>
            </div>
          </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <div class="dashboard-section">
      <div class="section-head">
        <h2><i class="fas fa-history"></i> Recent Test Results</h2>
        <a href="/my-tests" class="btn-sm">View All</a>
      </div>
      <% if (recentAttempts.length === 0) { %>
        <div class="empty-state-sm">
          <i class="fas fa-clipboard-list"></i>
          <p>No tests taken yet. <a href="/free-tests">Try a free test!</a></p>
        </div>
      <% } else { %>
        <div class="table-wrap">
          <table class="data-table">
            <thead><tr><th>Test</th><th>Score</th><th>Result</th><th>Date</th><th></th></tr></thead>
            <tbody>
              <% recentAttempts.forEach(a => { %>
              <tr>
                <td><%= a.testId ? a.testId.title : 'Unknown Test' %></td>
                <td><strong><%= a.score %>/<%= a.totalMarks %></strong></td>
                <td><span class="badge-result <%= a.passed ? 'badge-pass' : 'badge-fail' %>"><%= a.passed ? 'PASS' : 'FAIL' %></span></td>
                <td><%= new Date(a.completedAt).toLocaleDateString() %></td>
                <td><a href="/tests/result/<%= a._id %>" class="btn-xs">Review</a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
