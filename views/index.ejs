<%- include('partials/header') %>

<section class="hero" id="hero">
  <canvas id="hero-canvas"></canvas>
  <div class="hero-particles" id="particles"></div>
  <div class="hero-content">
    <div class="hero-badge" data-gsap="fade-up" data-delay="0">
      <span class="badge-dot"></span>
      <span>Nepal's #1 Exam Preparation Platform</span>
    </div>
    <h1 class="hero-title" data-gsap="fade-up" data-delay="0.1">
      <span class="hero-line">Crack Your</span>
      <span class="hero-line gradient-text">Dream Exam</span>
      <span class="hero-line">With Confidence</span>
    </h1>
    <p class="hero-desc" data-gsap="fade-up" data-delay="0.3">
      Expert-crafted courses for CEE, Loksewa, License, SEE & NEB. 
      Video lessons · Practice tests · Live doubt sessions · Weakness analysis.
    </p>
    <div class="hero-cta" data-gsap="fade-up" data-delay="0.5">
      <a href="/browse-courses" class="btn-magnetic btn-hero-primary">
        <span>Explore Courses</span>
        <i class="fas fa-arrow-right"></i>
      </a>
      <a href="/free-tests" class="btn-magnetic btn-hero-outline">
        <span>Try Free Tests</span>
        <i class="fas fa-flask"></i>
      </a>
    </div>
    <div class="hero-stats" data-gsap="fade-up" data-delay="0.7">
      <div class="hero-stat">
        <span class="stat-num" data-target="10000">0</span><span>+</span>
        <span class="stat-label">Students</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="stat-num" data-target="500">0</span><span>+</span>
        <span class="stat-label">Video Lessons</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="stat-num" data-target="95">0</span><span>%</span>
        <span class="stat-label">Pass Rate</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="stat-num" data-target="50">0</span><span>+</span>
        <span class="stat-label">Expert Teachers</span>
      </div>
    </div>
  </div>
  <div class="hero-scroll-indicator">
    <div class="scroll-line"></div>
    <span>Scroll to explore</span>
  </div>
</section>

<section class="categories-section" id="categories">
  <div class="container">
    <div class="section-header" data-gsap="fade-up">
      <span class="section-tag">What We Offer</span>
      <h2 class="section-title">Choose Your <span class="gradient-text">Exam Category</span></h2>
      <p class="section-desc">Specialized preparation programs designed by top educators for Nepal's most competitive exams</p>
    </div>
    <div class="categories-grid" id="categoriesGrid">
      <% if (categories && categories.length > 0) { %>
        <% categories.forEach((cat, i) => { %>
        <div class="category-card" data-tilt data-delay="<%= i * 0.1 %>" style="--card-color: <%= cat.color %>">
          <div class="card-glow"></div>
          <div class="card-inner">
            <div class="card-icon-wrap">
              <div class="card-icon-bg" style="background: <%= cat.color %>20">
                <i class="<%= cat.icon %>" style="color: <%= cat.color %>"></i>
              </div>
              <div class="icon-pulse" style="background: <%= cat.color %>"></div>
            </div>
            <h3 class="card-title"><%= cat.name %></h3>
            <p class="card-desc"><%= cat.description || '' %></p>
            <% if (cat.subjects && cat.subjects.length > 0) { %>
            <div class="subject-chips">
              <% cat.subjects.slice(0, 4).forEach(s => { %>
                <span class="chip" style="border-color: <%= cat.color %>40; color: <%= cat.color %>"><%= s %></span>
              <% }) %>
              <% if (cat.subjects.length > 4) { %><span class="chip chip-more">+<%= cat.subjects.length - 4 %> more</span><% } %>
            </div>
            <% } %>
            <a href="/browse-courses?category=<%= cat.slug %>" class="card-cta" style="color: <%= cat.color %>">
              View Courses <i class="fas fa-chevron-right"></i>
            </a>
          </div>
        </div>
        <% }) %>
      <% } else { %>
        <% [
          { name: 'CEE — Medical & Paramedical', icon: 'fas fa-stethoscope', color: '#00D4FF', desc: 'MBBS, BDS, BSc Nursing & B.Pharmacy — choose your program inside the course', subjects: ['MBBS', 'BDS', 'BSc Nursing', 'B.Pharmacy', 'Biology', 'Chemistry', 'Physics'], slug: 'cee-medical' },
          { name: 'CEE — BNS (B.N.Sc.)', icon: 'fas fa-heart-pulse', color: '#EC4899', desc: 'Bachelor of Nursing Science entrance — separate CEE track', subjects: ['Biology', 'Chemistry', 'Physics', 'English'], slug: 'cee-bns' },
          { name: 'IOE — Engineering', icon: 'fas fa-microchip', color: '#7C3AED', desc: 'Institute of Engineering entrance — BE, B.Arch, BEI programs', subjects: ['Mathematics', 'Physics', 'Chemistry', 'English'], slug: 'ioe-engineering' },
          { name: 'Loksewa / लोकसेवा', icon: 'fas fa-landmark', color: '#F59E0B', desc: 'Nepal Public Service Commission — all levels', subjects: ['GK / सामान्य ज्ञान', 'Current Affairs', 'IQ / Reasoning', 'Constitution'], slug: 'loksewa' },
          { name: 'License Exams', icon: 'fas fa-id-card', color: '#10B981', desc: 'Professional license exams for healthcare fields', subjects: ['Nursing License (NLEN)', 'CMLT License', 'Pharmacy License', 'HA License'], slug: 'license' },
          { name: 'SEE, Grade 11 & 12', icon: 'fas fa-school', color: '#F97316', desc: 'SEE, Grade 11 & Grade 12 — Science & Management streams', subjects: ['SEE — Grade 10', 'Grade 11', 'Grade 12'], slug: 'see-neb' }
        ].forEach((cat, i) => { %>
        <div class="category-card" data-tilt data-delay="<%= i * 0.1 %>" style="--card-color: <%= cat.color %>">
          <div class="card-glow"></div>
          <div class="card-inner">
            <div class="card-icon-wrap">
              <div class="card-icon-bg" style="background: <%= cat.color %>20">
                <i class="<%= cat.icon %>" style="color: <%= cat.color %>"></i>
              </div>
              <div class="icon-pulse" style="background: <%= cat.color %>"></div>
            </div>
            <h3 class="card-title"><%= cat.name %></h3>
            <p class="card-desc"><%= cat.desc %></p>
            <div class="subject-chips">
              <% cat.subjects.forEach(s => { %>
                <span class="chip" style="border-color: <%= cat.color %>40; color: <%= cat.color %>"><%= s %></span>
              <% }) %>
            </div>
            <a href="/browse-courses?category=<%= cat.slug %>" class="card-cta" style="color: <%= cat.color %>">
              View Courses <i class="fas fa-chevron-right"></i>
            </a>
          </div>
        </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<section class="features-section">
  <div class="container">
    <div class="section-header" data-gsap="fade-up">
      <span class="section-tag">Why Choose Us</span>
      <h2 class="section-title">Everything You Need to <span class="gradient-text">Succeed</span></h2>
    </div>
    <div class="features-grid">
      <% [
        { icon: 'fas fa-video', color: '#00D4FF', title: 'HD Video Lessons', desc: 'Crystal-clear videos with speed control, notes, and full protection' },
        { icon: 'fas fa-flask', color: '#7C3AED', title: 'Smart Practice Tests', desc: 'Timed tests with negative marking, question navigator, and detailed explanations' },
        { icon: 'fas fa-bolt', color: '#F59E0B', title: '⚡ Weakness Analyzer Pro', desc: 'Auto-tracks wrong answers. Critical weakness detection. Custom quiz generation.' },
        { icon: 'fas fa-shield-halved', color: '#10B981', title: 'Video Protection', desc: 'Dynamic watermarking, forensic tracking, signed URLs – your content is safe' },
        { icon: 'fas fa-chart-line', color: '#EC4899', title: 'Progress Tracking', desc: 'Real-time progress dashboard with charts, streaks, and milestone badges' },
        { icon: 'fas fa-mobile-screen', color: '#8B5CF6', title: 'Mobile Optimized', desc: 'Learn on any device with GPU-accelerated animations and offline support' }
      ].forEach((f, i) => { %>
      <div class="feature-card" data-gsap="fade-up" data-delay="<%= i * 0.1 %>">
        <div class="feature-icon" style="background: <%= f.color %>15; color: <%= f.color %>">
          <i class="<%= f.icon %>"></i>
        </div>
        <h3><%= f.title %></h3>
        <p><%= f.desc %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<% if (featuredCourses && featuredCourses.length > 0) { %>
<section class="courses-section">
  <div class="container">
    <div class="section-header" data-gsap="fade-up">
      <span class="section-tag">Top Picks</span>
      <h2 class="section-title">Featured <span class="gradient-text">Courses</span></h2>
    </div>
    <div class="courses-grid">
      <% featuredCourses.forEach((course, i) => { %>
      <div class="course-card" data-gsap="fade-up" data-delay="<%= i * 0.1 %>">
        <div class="course-img-wrap">
          <% if (course.imageUrl) { %>
            <img src="<%= course.imageUrl %>" alt="<%= course.title %>" loading="lazy">
          <% } else { %>
            <div class="course-img-placeholder"><i class="fas fa-book-open"></i></div>
          <% } %>
          <div class="course-badge"><%= course.category %></div>
        </div>
        <div class="course-body">
          <h3 class="course-title"><%= course.title %></h3>
          <p class="course-desc"><%= course.description.substring(0, 100) %>...</p>
          <div class="course-meta">
            <% if (course.examType) { %><span><i class="fas fa-layer-group"></i> <%= course.examType %></span><% } %>
            <span><i class="fas fa-users"></i> <%= course.enrolledCount || 0 %> enrolled</span>
          </div>
          <div class="course-footer">
            <div class="course-price">
              <% if (course.price === 0) { %>
                <span class="price-free">FREE</span>
              <% } else { %>
                <span class="price-amount">Rs. <%= course.price.toLocaleString() %></span>
              <% } %>
            </div>
            <a href="/courses/<%= course._id %>" class="btn-enroll">
              <span>View Course</span>
              <i class="fas fa-arrow-right"></i>
            </a>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <div class="section-cta" data-gsap="fade-up">
      <a href="/browse-courses" class="btn-magnetic btn-hero-primary">
        <span>View All Courses</span>
        <i class="fas fa-th-large"></i>
      </a>
    </div>
  </div>
</section>
<% } %>

<section class="testimonials-section">
  <div class="container">
    <div class="section-header" data-gsap="fade-up">
      <span class="section-tag">Success Stories</span>
      <h2 class="section-title">Students Who <span class="gradient-text">Made It</span></h2>
    </div>
    <div class="testimonials-grid">
      <% [
        { name: 'Aarav Sharma', exam: 'CEE 2080 – MBBS', text: 'Learn With Saurab\'s Weakness Analyzer literally identified my Chemistry weak spots. Cleared CEE with 89%!', score: '89%', avatar: 'A' },
        { name: 'Priya Karki', exam: 'Loksewa – Section Officer', text: 'The IQ/Reasoning video lessons and mock tests were exactly like the real exam. Highly recommend!', score: 'Passed', avatar: 'P' },
        { name: 'Bikash Thapa', exam: 'Nursing License (NLEN) 2080', text: 'Video protection means I know I\'m watching premium content. The explanations are unmatched in Nepal.', score: '92%', avatar: 'B' }
      ].forEach((t, i) => { %>
      <div class="testimonial-card" data-gsap="fade-up" data-delay="<%= i * 0.15 %>">
        <div class="testimonial-quote"><i class="fas fa-quote-left"></i></div>
        <p class="testimonial-text"><%= t.text %></p>
        <div class="testimonial-author">
          <div class="testimonial-avatar"><%= t.avatar %></div>
          <div>
            <strong><%= t.name %></strong>
            <span><%= t.exam %></span>
          </div>
          <div class="testimonial-score"><%= t.score %></div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="cta-bg-animation"></div>
  <div class="container">
    <div class="cta-content" data-gsap="fade-up">
      <h2>Ready to Start Your <span class="gradient-text">Success Journey?</span></h2>
      <p>Join 10,000+ students already preparing with Nepal's most advanced exam platform</p>
      <div class="cta-buttons">
        <a href="/signup" class="btn-magnetic btn-hero-primary">
          <span>Create Free Account</span>
          <i class="fas fa-user-plus"></i>
        </a>
        <a href="/browse-courses" class="btn-magnetic btn-hero-outline">
          <span>Browse Courses</span>
          <i class="fas fa-search"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer', { extraJs: `
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="/js/three-init.js"></script>
<script src="/js/content-protection.js"></script>
` }) %>
