<%- include('partials/header') %>

<div class="course-preview-page">
  <div class="course-hero">
    <div class="container">
      <div class="course-hero-grid">
        <div class="course-hero-info">
          <div class="breadcrumb">
            <a href="/browse-courses">Courses</a> <i class="fas fa-chevron-right"></i>
            <span><%= course.category %></span> <i class="fas fa-chevron-right"></i>
            <span><%= course.title %></span>
          </div>
          <% if (course.isFeatured) { %><div class="featured-tag"><i class="fas fa-star"></i> Featured Course</div><% } %>
          <h1><%= course.title %></h1>
          <p class="course-hero-desc"><%= course.description %></p>
          <div class="course-hero-meta">
            <span><i class="fas fa-layer-group"></i> <%= course.level %></span>
            <span><i class="fas fa-tag"></i> <%= course.category %></span>
            <% if (course.subject) { %><span><i class="fas fa-book"></i> <%= course.subject %></span><% } %>
            <span><i class="fas fa-users"></i> <%= course.enrolledCount || 0 %> students</span>
          </div>
        </div>
        <div class="course-hero-card">
          <% if (course.imageUrl) { %>
            <img src="<%= course.imageUrl %>" alt="<%= course.title %>" class="course-card-img">
          <% } else { %>
            <div class="course-card-placeholder"><i class="fas fa-play-circle"></i></div>
          <% } %>
          <div class="course-card-pricing">
            <% if (course.price === 0) { %>
              <div class="price-free-big">FREE</div>
            <% } else { %>
              <div class="price-big">Rs. <%= course.price.toLocaleString() %></div>
            <% } %>
            <% if (isEnrolled) { %>
              <a href="/courses/<%= course._id %>/learn" class="btn-enroll-big btn-continue">
                <i class="fas fa-play"></i> Continue Learning
              </a>
            <% } else if (course.price === 0) { %>
              <a href="/payment/enroll/<%= course._id %>" class="btn-enroll-big">
                <i class="fas fa-graduation-cap"></i> Enroll Free
              </a>
            <% } else { %>
              <a href="/payment/enroll/<%= course._id %>" class="btn-enroll-big btn-pay">
                <i class="fas fa-lock-open"></i> Enroll Now
              </a>
              <div class="payment-logos">
                <span>Pay with</span>
                <img src="/images/esewa.png" alt="eSewa" onerror="this.style.display='none'">
                <img src="/images/khalti.png" alt="Khalti" onerror="this.style.display='none'">
              </div>
            <% } %>
            <div class="course-guarantees">
              <span><i class="fas fa-infinity"></i> Lifetime access</span>
              <span><i class="fas fa-mobile-screen"></i> Mobile friendly</span>
              <span><i class="fas fa-certificate"></i> Certificate</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container course-detail-body">
    <div class="course-detail-grid">
      <div class="course-detail-main">

        <!-- Demo Lecture Section -->
        <% if (course.demoVideoUrl) { %>
        <div class="detail-section demo-lecture-section" style="margin-bottom:28px">
          <h2 style="margin-bottom:16px"><i class="fas fa-play-circle" style="color:#00D4FF"></i> Free Demo Lecture
            <span style="font-size:13px;font-weight:400;color:#10B981;margin-left:8px;background:rgba(16,185,129,0.1);padding:3px 10px;border-radius:20px">Watch Free — No Login Needed</span>
          </h2>
          <% if (course.demoTitle) { %><p style="color:#9CA3AF;font-size:15px;margin-bottom:14px"><i class="fas fa-film"></i> <%= course.demoTitle %></p><% } %>
          <% if (course.demoVideoType === 'youtube' && course.demoVideoUrl) { %>
            <%
              let ytId = '';
              const ytUrl = course.demoVideoUrl;
              const matchV = ytUrl.match(/[?&]v=([^&#]+)/);
              const matchShort = ytUrl.match(/youtu\.be\/([^?&#]+)/);
              const matchEmbed = ytUrl.match(/embed\/([^?&#]+)/);
              if (matchV) ytId = matchV[1];
              else if (matchShort) ytId = matchShort[1];
              else if (matchEmbed) ytId = matchEmbed[1];
            %>
            <% if (ytId) { %>
            <div class="demo-video-wrap" style="position:relative;padding-bottom:56.25%;height:0;border-radius:12px;overflow:hidden;background:#000">
              <iframe
                src="https://www.youtube.com/embed/<%= ytId %>?rel=0&modestbranding=1"
                style="position:absolute;top:0;left:0;width:100%;height:100%;border:none"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen loading="lazy" title="Demo Lecture"></iframe>
            </div>
            <% } else { %>
            <a href="<%= course.demoVideoUrl %>" target="_blank" class="btn-enroll-big" style="display:inline-flex;align-items:center;gap:8px;text-decoration:none;margin-top:8px">
              <i class="fab fa-youtube"></i> Watch on YouTube
            </a>
            <% } %>
          <% } else if (course.demoVideoType === 'local' && course.demoVideoUrl) { %>
            <div class="demo-video-wrap" style="border-radius:12px;overflow:hidden;background:#000">
              <video controls controlsList="nodownload nofullscreen" oncontextmenu="return false"
                style="width:100%;max-height:450px;display:block"
                poster="<%= course.imageUrl || '' %>">
                <source src="<%= course.demoVideoUrl %>" type="video/mp4">
                Your browser does not support video playback.
              </video>
            </div>
          <% } %>
          <p style="font-size:12px;color:#6B7280;margin-top:10px"><i class="fas fa-lock"></i> Full course content available after enrollment</p>
        </div>
        <% } %>

        <% if (course.modules && course.modules.length > 0) { %>
        <div class="detail-section">
          <h2><i class="fas fa-list-check"></i> Course Curriculum</h2>
          <div class="curriculum-list">
            <% let totalVideos = 0; course.modules.forEach((mod, mi) => { %>
            <div class="curriculum-module">
              <div class="module-header" onclick="toggleModule(<%= mi %>)">
                <span class="module-num">Module <%= mi + 1 %></span>
                <h3><%= mod.moduleTitle %></h3>
                <span class="module-toggle" id="toggle-<%= mi %>"><i class="fas fa-chevron-down"></i></span>
              </div>
              <div class="module-videos" id="module-<%= mi %>">
                <% mod.videos && mod.videos.forEach(v => { totalVideos++; %>
                <div class="video-item">
                  <i class="fas fa-<%= v.isFree ? 'play-circle text-teal' : 'lock text-gray' %>"></i>
                  <span><%= v.videoTitle %></span>
                  <span class="video-badge"><%= v.isFree ? 'Free' : 'Premium' %></span>
                </div>
                <% }) %>
              </div>
            </div>
            <% }) %>
          </div>
          <p class="curriculum-total"><%= totalVideos %> total lessons across <%= course.modules.length %> modules</p>
        </div>
        <% } %>
      </div>
      <% if (related && related.length > 0) { %>
      <div class="course-detail-sidebar">
        <h3>Related Courses</h3>
        <% related.forEach(r => { %>
        <a href="/courses/<%= r._id %>" class="related-course-card">
          <div class="related-img">
            <% if (r.imageUrl) { %><img src="<%= r.imageUrl %>" alt="<%= r.title %>"><% } else { %><i class="fas fa-book"></i><% } %>
          </div>
          <div>
            <h4><%= r.title %></h4>
            <span><%= r.price === 0 ? 'FREE' : 'Rs. ' + r.price.toLocaleString() %></span>
          </div>
        </a>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer', { extraJs: `<script>
function toggleModule(idx) {
  const el = document.getElementById('module-' + idx);
  const tog = document.getElementById('toggle-' + idx);
  el.classList.toggle('open');
  tog.querySelector('i').className = el.classList.contains('open') ? 'fas fa-chevron-up' : 'fas fa-chevron-down';
}
document.querySelector('.curriculum-module .module-header') && toggleModule(0);
</script>` }) %>
