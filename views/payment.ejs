<%- include('partials/header') %>

<div class="page-hero page-hero-sm">
  <div class="container">
    <h1>Enroll in <span class="gradient-text"><%= course.title %></span></h1>
    <p class="hero-sub">Secure checkout — Lifetime access</p>
  </div>
</div>

<div class="container payment-page">
  <div class="payment-grid">

    <!-- ── Order Summary ─────────────────────────────── -->
    <div class="payment-summary">
      <h2><i class="fas fa-receipt"></i> Order Summary</h2>
      <div class="order-course">
        <% if (course.imageUrl) { %>
          <img src="<%= course.imageUrl %>" alt="<%= course.title %>">
        <% } else { %>
          <div class="order-thumb-placeholder"><i class="fas fa-book-open"></i></div>
        <% } %>
        <div class="order-course-info">
          <h3><%= course.title %></h3>
          <span class="order-meta">
            <% if (course.examType) { %><i class="fas fa-tag"></i> <%= course.examType %><% } %>
            <% if (course.subject) { %> · <%= course.subject %><% } %>
          </span>
        </div>
      </div>

      <div class="order-details">
        <div class="order-row"><span>Course Price</span><span>Rs. <%= course.price.toLocaleString() %></span></div>
        <div class="order-row order-total">
          <strong>Total Payable</strong>
          <strong class="price-highlight">Rs. <%= course.price.toLocaleString() %></strong>
        </div>
      </div>

      <div class="order-guarantees">
        <div class="guarantee-item"><i class="fas fa-infinity text-teal"></i><span>Lifetime access</span></div>
        <div class="guarantee-item"><i class="fas fa-redo text-teal"></i><span>7-day refund policy</span></div>
        <div class="guarantee-item"><i class="fas fa-shield-alt text-teal"></i><span>Secure payment</span></div>
        <div class="guarantee-item"><i class="fas fa-video text-teal"></i><span>HD video lessons</span></div>
      </div>

      <div class="enrolled-info">
        <i class="fas fa-users"></i>
        <span><strong><%= course.enrolledCount || 0 %>+ students</strong> already enrolled</span>
      </div>
    </div>

    <!-- ── Payment Methods ────────────────────────────── -->
    <div class="payment-methods">
      <h2><i class="fas fa-credit-card"></i> Choose Payment Method</h2>

      <div class="payment-options">

        <!-- eSewa -->
        <button class="payment-option active" id="opt-esewa" onclick="selectPayment('esewa')">
          <div class="payment-option-inner">
            <div class="payment-logo-wrap esewa-logo">
              <svg width="36" height="36" viewBox="0 0 40 40" fill="none">
                <rect width="40" height="40" rx="8" fill="#60BB46"/>
                <text x="20" y="26" text-anchor="middle" fill="white" font-size="11" font-weight="800" font-family="Arial">eSewa</text>
              </svg>
            </div>
            <div class="payment-method-info">
              <span class="payment-method-name">eSewa</span>
              <span class="payment-method-sub">Nepal's most used digital wallet</span>
            </div>
          </div>
          <div class="payment-selected-indicator"><i class="fas fa-check-circle"></i></div>
        </button>

        <!-- Khalti -->
        <button class="payment-option" id="opt-khalti" onclick="selectPayment('khalti')">
          <div class="payment-option-inner">
            <div class="payment-logo-wrap khalti-logo">
              <svg width="36" height="36" viewBox="0 0 40 40" fill="none">
                <rect width="40" height="40" rx="8" fill="#5C2D91"/>
                <text x="20" y="26" text-anchor="middle" fill="white" font-size="9" font-weight="800" font-family="Arial">Khalti</text>
              </svg>
            </div>
            <div class="payment-method-info">
              <span class="payment-method-name">Khalti</span>
              <span class="payment-method-sub">Fast & secure digital payment</span>
            </div>
          </div>
          <div class="payment-selected-indicator"><i class="fas fa-check-circle"></i></div>
        </button>

      </div>

      <!-- Payment info note (changes by method) -->
      <div class="payment-method-note" id="payNote">
        <i class="fas fa-info-circle"></i>
        <span id="payNoteText">You will be redirected to eSewa to complete your payment securely.</span>
      </div>

      <!-- Error alert -->
      <div class="payment-error" id="payError" style="display:none">
        <i class="fas fa-exclamation-triangle"></i>
        <span id="payErrorText">Payment failed. Please try again.</span>
      </div>

      <!-- Pay button -->
      <button class="btn-pay-now" id="payBtn" onclick="initiatePayment()">
        <i class="fas fa-lock" id="payBtnIcon"></i>
        <span id="payBtnText">Pay Rs. <%= course.price.toLocaleString() %> Securely</span>
      </button>

      <div class="ssl-note">
        <i class="fas fa-shield-alt"></i>
        256-bit SSL encrypted &nbsp;·&nbsp; 100% secure
      </div>

      <div class="back-link">
        <a href="/courses/<%= course._id %>"><i class="fas fa-arrow-left"></i> Back to course</a>
      </div>
    </div>

  </div>
</div>

<style>
.payment-page { padding: 48px 0 80px; }
.payment-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; max-width: 900px; margin: 0 auto; }
.payment-summary, .payment-methods {
  background: #161D2E; border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px; padding: 28px;
}
.payment-summary h2, .payment-methods h2 {
  font-family: 'Montserrat', sans-serif; font-size: 18px; font-weight: 800;
  margin-bottom: 20px; display: flex; align-items: center; gap: 10px; color: #F9FAFB;
}
.payment-summary h2 i, .payment-methods h2 i { color: #00D4FF; }

/* Order course */
.order-course { display: flex; gap: 14px; align-items: flex-start; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.06); }
.order-course img { width: 80px; height: 56px; object-fit: cover; border-radius: 8px; flex-shrink: 0; }
.order-thumb-placeholder { width: 80px; height: 56px; background: rgba(0,212,255,0.1); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #00D4FF; font-size: 22px; flex-shrink: 0; }
.order-course-info h3 { font-size: 15px; font-weight: 700; color: #F9FAFB; line-height: 1.4; margin-bottom: 4px; }
.order-meta { font-size: 12px; color: #6B7280; }

/* Order details */
.order-details { margin-bottom: 20px; }
.order-row { display: flex; justify-content: space-between; align-items: center; padding: 8px 0; font-size: 14px; color: #9CA3AF; border-bottom: 1px solid rgba(255,255,255,0.04); }
.order-total { border-bottom: none; padding-top: 12px; margin-top: 4px; color: #F9FAFB; font-size: 16px; }
.price-highlight { color: #00D4FF; font-size: 20px; font-family: 'Montserrat', sans-serif; }

/* Guarantees */
.order-guarantees { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
.guarantee-item { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #9CA3AF; }
.guarantee-item i { width: 16px; flex-shrink: 0; }
.enrolled-info { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #6B7280; background: rgba(0,212,255,0.05); border: 1px solid rgba(0,212,255,0.1); border-radius: 8px; padding: 10px 14px; }
.enrolled-info i { color: #00D4FF; }

/* Payment options */
.payment-options { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
.payment-option {
  background: rgba(255,255,255,0.02); border: 2px solid rgba(255,255,255,0.08);
  border-radius: 12px; padding: 16px 18px; cursor: pointer; transition: all 0.2s;
  display: flex; align-items: center; justify-content: space-between;
  text-align: left; width: 100%;
}
.payment-option:hover { border-color: rgba(0,212,255,0.25); background: rgba(0,212,255,0.03); }
.payment-option.active { border-color: #00D4FF; background: rgba(0,212,255,0.06); }
.payment-option-inner { display: flex; align-items: center; gap: 14px; }
.payment-logo-wrap { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden; }
.payment-method-info { display: flex; flex-direction: column; gap: 2px; }
.payment-method-name { font-weight: 700; font-size: 15px; color: #F9FAFB; }
.payment-method-sub { font-size: 12px; color: #6B7280; }
.payment-selected-indicator { color: rgba(255,255,255,0.15); font-size: 20px; transition: color 0.2s; }
.payment-option.active .payment-selected-indicator { color: #00D4FF; }

/* Note */
.payment-method-note { display: flex; align-items: flex-start; gap: 8px; font-size: 13px; color: #6B7280; background: rgba(255,255,255,0.03); border-radius: 8px; padding: 10px 14px; margin-bottom: 16px; }
.payment-method-note i { color: #00D4FF; margin-top: 1px; flex-shrink: 0; }

/* Error */
.payment-error { display: flex; align-items: center; gap: 10px; font-size: 13px; color: #EF4444; background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 8px; padding: 12px 14px; margin-bottom: 14px; }

/* Pay button */
.btn-pay-now {
  width: 100%; padding: 16px 24px; border: none; border-radius: 12px;
  background: linear-gradient(135deg, #00D4FF 0%, #7C3AED 100%);
  color: #fff; font-size: 16px; font-weight: 800; cursor: pointer;
  transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 10px;
  font-family: 'Montserrat', sans-serif; letter-spacing: 0.3px;
}
.btn-pay-now:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,212,255,0.35); }
.btn-pay-now:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
.btn-pay-now.khalti-btn { background: linear-gradient(135deg, #5C2D91 0%, #8B5CF6 100%); }
.btn-pay-now.khalti-btn:hover:not(:disabled) { box-shadow: 0 8px 30px rgba(92,45,145,0.45); }

.ssl-note { text-align: center; font-size: 12px; color: #4B5563; margin-top: 14px; display: flex; align-items: center; justify-content: center; gap: 6px; }
.ssl-note i { color: #10B981; }
.back-link { text-align: center; margin-top: 16px; }
.back-link a { font-size: 13px; color: #6B7280; text-decoration: none; transition: color 0.2s; }
.back-link a:hover { color: #00D4FF; }

@media (max-width: 768px) {
  .payment-grid { grid-template-columns: 1fr; gap: 20px; }
  .order-guarantees { grid-template-columns: 1fr; }
}
</style>

<%- include('partials/footer', { extraJs: `<script>
const COURSE_ID = '<%= course._id %>';
const COURSE_PRICE = <%= course.price %>;
let selectedMethod = 'esewa';

function selectPayment(method) {
  selectedMethod = method;
  document.querySelectorAll('.payment-option').forEach(el => el.classList.remove('active'));
  document.getElementById('opt-' + method).classList.add('active');

  const btn = document.getElementById('payBtn');
  const noteText = document.getElementById('payNoteText');

  if (method === 'khalti') {
    btn.className = 'btn-pay-now khalti-btn';
    noteText.textContent = 'You will be redirected to Khalti to complete your payment securely.';
  } else {
    btn.className = 'btn-pay-now';
    noteText.textContent = 'You will be redirected to eSewa to complete your payment securely.';
  }
  document.getElementById('payError').style.display = 'none';
}

async function initiatePayment() {
  const btn = document.getElementById('payBtn');
  const errorDiv = document.getElementById('payError');
  const errorText = document.getElementById('payErrorText');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>Processing...</span>';
  errorDiv.style.display = 'none';

  try {
    if (selectedMethod === 'esewa') {
      const res = await fetch('/payment/esewa/initiate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ courseId: COURSE_ID })
      });
      const data = await res.json();
      if (data.success) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = data.esewaUrl;
        Object.entries(data.esewaData).forEach(([k, v]) => {
          const inp = document.createElement('input');
          inp.type = 'hidden'; inp.name = k; inp.value = v;
          form.appendChild(inp);
        });
        document.body.appendChild(form);
        form.submit();
        return;
      }
      throw new Error(data.message || 'eSewa initiation failed');

    } else if (selectedMethod === 'khalti') {
      const res = await fetch('/payment/khalti/initiate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ courseId: COURSE_ID })
      });
      const data = await res.json();
      if (data.success && data.payment_url) {
        window.location.href = data.payment_url;
        return;
      }
      throw new Error(data.message || 'Khalti initiation failed');
    }
  } catch (err) {
    errorText.textContent = err.message || 'Payment failed. Please try again.';
    errorDiv.style.display = 'flex';
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-lock"></i><span>Pay Rs. ' + COURSE_PRICE.toLocaleString('en-NP') + ' Securely</span>';
    if (selectedMethod === 'khalti') btn.className = 'btn-pay-now khalti-btn';
    else btn.className = 'btn-pay-now';
  }
}
</script>` }) %>
