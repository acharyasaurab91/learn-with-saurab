<%- include('partials/header') %>
<div class="page-hero page-hero-sm">
  <div class="container"><h1>Enroll in <span class="gradient-text"><%= course.title %></span></h1></div>
</div>
<div class="container payment-page">
  <div class="payment-grid">
    <div class="payment-summary">
      <h2>Order Summary</h2>
      <div class="order-course">
        <% if (course.imageUrl) { %><img src="<%= course.imageUrl %>" alt="<%= course.title %>"><% } %>
        <div>
          <h3><%= course.title %></h3>
          <span><%= course.category %> · <%= course.level %></span>
        </div>
      </div>
      <div class="order-details">
        <div class="order-row"><span>Course Price</span><span>Rs. <%= course.price.toLocaleString() %></span></div>
        <div class="order-row order-total"><strong>Total</strong><strong>Rs. <%= course.price.toLocaleString() %></strong></div>
      </div>
      <div class="order-guarantees">
        <span><i class="fas fa-infinity"></i> Lifetime access</span>
        <span><i class="fas fa-redo"></i> 7-day refund policy</span>
        <span><i class="fas fa-shield-alt"></i> Secure payment</span>
      </div>
    </div>
    <div class="payment-methods">
      <h2>Choose Payment Method</h2>
      <div class="payment-options">
        <button class="payment-option active" onclick="selectPayment('esewa')">
          <div class="payment-logo">eSewa</div>
          <span>Pay with eSewa</span>
        </button>
        <button class="payment-option" onclick="selectPayment('khalti')">
          <div class="payment-logo">Khalti</div>
          <span>Pay with Khalti</span>
        </button>
      </div>
      <button class="btn-pay-now" onclick="initiatePayment()">
        <i class="fas fa-lock"></i>
        <span>Pay Rs. <%= course.price.toLocaleString() %> Securely</span>
      </button>
      <p class="payment-note"><i class="fas fa-shield-alt"></i> 256-bit SSL encrypted payment</p>
    </div>
  </div>
</div>
<%- include('partials/footer', { extraJs: `<script>
let selectedMethod = 'esewa';
function selectPayment(m) {
  selectedMethod = m;
  document.querySelectorAll('.payment-option').forEach(el => el.classList.remove('active'));
  event.target.closest('.payment-option').classList.add('active');
}
async function initiatePayment() {
  const btn = document.querySelector('.btn-pay-now');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
  const res = await fetch('/payment/esewa/initiate', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ courseId: '<%= course._id %>' })
  });
  const data = await res.json();
  if (data.success) {
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = data.esewaUrl;
    Object.entries(data.esewaData).forEach(([k, v]) => {
      const inp = document.createElement('input');
      inp.type = 'hidden'; inp.name = k; inp.value = v;
      form.appendChild(inp);
    });
    document.body.appendChild(form);
    form.submit();
  } else {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-lock"></i> Pay Securely';
    alert('Payment initiation failed. Please try again.');
  }
}
</script>` }) %>
