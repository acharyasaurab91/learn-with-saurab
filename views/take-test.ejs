<%- include('partials/header', { extraCss: '<link rel="stylesheet" href="/css/test.css">' }) %>

<div class="test-page" id="testPage">
  <div class="test-header">
    <div class="test-header-left">
      <h2><%= test.title %></h2>
      <span class="test-total"><%= test.questions.length %> Questions · <%= test.totalMarks || test.questions.length %> Marks</span>
    </div>
    <div class="test-timer" id="timer">
      <i class="fas fa-clock"></i>
      <span id="timerDisplay">--:--</span>
    </div>
    <button class="btn-submit-test" onclick="confirmSubmit()">
      <i class="fas fa-paper-plane"></i> Submit Test
    </button>
  </div>

  <div class="test-body">
    <div class="test-question-panel" id="questionPanel">
      <div class="question-progress">
        <span id="qProgress">Question 1 of <%= test.questions.length %></span>
        <div class="progress-bar-wrap"><div class="progress-bar-fill" id="qProgressBar" style="width: 0%"></div></div>
      </div>
      <div class="question-card" id="questionCard">
        <div class="question-number" id="qNum">Q1</div>
        <div class="question-text" id="qText"></div>
        <div class="question-img-wrap" id="qImgWrap" style="display:none">
          <img id="qImg" src="" alt="Question image">
        </div>
        <div class="options-grid" id="optionsGrid"></div>
        <div class="question-nav-btns">
          <button class="btn-nav" onclick="prevQuestion()" id="prevBtn" disabled>
            <i class="fas fa-arrow-left"></i> Previous
          </button>
          <button class="btn-mark" onclick="markForReview()" id="markBtn">
            <i class="fas fa-bookmark"></i> Mark for Review
          </button>
          <button class="btn-nav btn-next" onclick="nextQuestion()" id="nextBtn">
            Next <i class="fas fa-arrow-right"></i>
          </button>
        </div>
      </div>
    </div>

    <div class="test-sidebar">
      <div class="sidebar-section">
        <h3>Question Navigator</h3>
        <div class="question-grid" id="questionGrid">
          <% test.questions.forEach((q, i) => { %>
          <button class="qgrid-btn" id="qgrid-<%= i %>" onclick="goToQuestion(<%= i %>)"><%= i + 1 %></button>
          <% }) %>
        </div>
        <div class="legend">
          <span class="legend-item"><span class="legend-dot dot-unanswered"></span>Unanswered</span>
          <span class="legend-item"><span class="legend-dot dot-answered"></span>Answered</span>
          <span class="legend-item"><span class="legend-dot dot-review"></span>Review</span>
        </div>
      </div>
      <div class="sidebar-section">
        <h3>Summary</h3>
        <div class="summary-stats">
          <div><span id="answeredCount">0</span> Answered</div>
          <div><span id="unansweredCount"><%= test.questions.length %></span> Unanswered</div>
          <div><span id="reviewCount">0</span> Marked</div>
        </div>
      </div>
      <button class="btn-submit-test w-full mt-2" onclick="confirmSubmit()">
        <i class="fas fa-paper-plane"></i> Submit Test
      </button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="submitModal" style="display:none">
  <div class="modal-card">
    <div class="modal-header">
      <h3><i class="fas fa-paper-plane"></i> Submit Test?</h3>
    </div>
    <div class="modal-body">
      <p>You've answered <strong id="modalAnswered">0</strong> of <strong><%= test.questions.length %></strong> questions.</p>
      <p id="reviewWarning" class="text-yellow"></p>
      <p>Once submitted, you cannot change your answers.</p>
    </div>
    <div class="modal-actions">
      <button onclick="closeSubmitModal()" class="btn-secondary">Continue Test</button>
      <button onclick="submitTest()" class="btn-auth">Submit Now</button>
    </div>
  </div>
</div>

<%- include('partials/footer', { extraJs: `
<script>
const TEST_DATA = {
  testId: '<%= test._id %>',
  duration: <%= test.duration %>,
  questions: <%- safeQuestions %>,
  negativeMarking: <%= test.negativeMarking %>,
  negativeMarkValue: <%= test.negativeMarkValue || 0.25 %>
};
</script>
<script src="/js/test-timer.js"></script>
<script src="/js/content-protection.js"></script>
` }) %>
