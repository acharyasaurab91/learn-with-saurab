<%- include('partials/header') %>
<div class="page-hero page-hero-sm">
  <div class="container">
    <h1>Contact <span class="gradient-text">Saurab Sir</span></h1>
    <p>Have questions? We're here to help you succeed in your exams</p>
  </div>
</div>
<div class="container contact-page">
  <div class="contact-grid">
    <div class="contact-info">
      <h2>Get in Touch</h2>
      <div class="contact-item">
        <i class="fas fa-envelope text-teal"></i>
        <div>
          <h4>Email</h4>
          <p><a href="mailto:contactsaurabsir@gmail.com" style="color:var(--color-teal);text-decoration:none">contactsaurabsir@gmail.com</a></p>
        </div>
      </div>
      <div class="contact-item">
        <i class="fab fa-youtube" style="color:#EF4444"></i>
        <div>
          <h4>YouTube</h4>
          <p><a href="https://youtube.com/@learnwithsaurabsir" target="_blank" rel="noopener" style="color:var(--color-teal);text-decoration:none">@learnwithsaurabsir</a></p>
        </div>
      </div>
      <div class="contact-item">
        <i class="fab fa-facebook-f" style="color:#1877F2"></i>
        <div>
          <h4>Facebook</h4>
          <p><a href="https://www.facebook.com/share/1B9GkvjhNV/" target="_blank" rel="noopener" style="color:var(--color-teal);text-decoration:none">Learn With Saurab</a></p>
        </div>
      </div>
      <div class="contact-item">
        <i class="fab fa-instagram" style="color:#E1306C"></i>
        <div>
          <h4>Instagram</h4>
          <p><a href="https://www.instagram.com/learnwithsaurab" target="_blank" rel="noopener" style="color:var(--color-teal);text-decoration:none">@learnwithsaurab</a></p>
        </div>
      </div>
      <div class="contact-item">
        <i class="fab fa-tiktok" style="color:#F9FAFB"></i>
        <div>
          <h4>TikTok</h4>
          <p><a href="https://www.tiktok.com/@learnwithsaurab" target="_blank" rel="noopener" style="color:var(--color-teal);text-decoration:none">@learnwithsaurab</a></p>
        </div>
      </div>
      <div class="contact-item">
        <i class="fas fa-map-marker-alt text-purple"></i>
        <div>
          <h4>Location</h4>
          <p>Kathmandu, Nepal 🇳🇵</p>
        </div>
      </div>
    </div>
    <div class="contact-form-wrap">
      <h2>Send a Message</h2>
      <div id="contactSuccess" style="display:none" class="alert alert-success" style="margin-bottom:16px">
        <i class="fas fa-check-circle"></i> Message sent! We'll respond within 24 hours.
      </div>
      <form class="auth-form" id="contactForm" onsubmit="sendContact(event)">
        <div class="form-row-2">
          <div class="form-group"><label>Your Name</label><input type="text" name="name" required placeholder="Your full name"></div>
          <div class="form-group"><label>Email</label><input type="email" name="email" required placeholder="your@email.com"></div>
        </div>
        <div class="form-group"><label>Subject</label>
          <select name="subject">
            <option value="">Select a topic</option>
            <option>Course Inquiry</option>
            <option>CEE Medical/BNS</option>
            <option>IOE Engineering</option>
            <option>Loksewa Preparation</option>
            <option>License Exam</option>
            <option>Technical Issue</option>
            <option>Payment Support</option>
            <option>Other</option>
          </select>
        </div>
        <div class="form-group"><label>Message</label><textarea rows="5" name="message" placeholder="Describe your query in detail..." required></textarea></div>
        <button type="submit" class="btn-auth"><span>Send Message</span><i class="fas fa-paper-plane"></i></button>
      </form>
    </div>
  </div>
</div>
<%- include('partials/footer', { extraJs: `<script>
function sendContact(e) {
  e.preventDefault();
  const btn = e.target.querySelector('button[type="submit"]');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
  setTimeout(() => {
    document.getElementById('contactSuccess').style.display = 'flex';
    e.target.reset();
    btn.disabled = false;
    btn.innerHTML = '<span>Send Message</span><i class="fas fa-paper-plane"></i>';
  }, 1000);
}
</script>` }) %>
