<div class="dashboard-sidebar">
  <div class="sidebar-user">
    <div class="sidebar-avatar"><%= user.firstName[0] %><%= user.lastName[0] %></div>
    <div>
      <strong><%= user.firstName %> <%= user.lastName %></strong>
      <span><%= user.email %></span>
    </div>
  </div>
  <nav class="sidebar-nav">
    <a href="/dashboard"        class="sidebar-link <%= (typeof active !== 'undefined' && active === 'dashboard')    ? 'active' : '' %>"><i class="fas fa-th-large"></i> Dashboard</a>
    <a href="/my-courses"       class="sidebar-link <%= (typeof active !== 'undefined' && active === 'my-courses')   ? 'active' : '' %>"><i class="fas fa-book-open"></i> My Courses</a>
    <a href="/my-tests"         class="sidebar-link <%= (typeof active !== 'undefined' && active === 'my-tests')     ? 'active' : '' %>"><i class="fas fa-clipboard-list"></i> My Tests</a>
    <a href="/mistake-notebook" class="sidebar-link <%= (typeof active !== 'undefined' && active === 'weakness')     ? 'active' : '' %>"><i class="fas fa-bolt"></i> Weakness Analyzer</a>
    <a href="/profile"          class="sidebar-link <%= (typeof active !== 'undefined' && active === 'profile')      ? 'active' : '' %>"><i class="fas fa-user-cog"></i> Profile</a>
    <% if (user.isAdmin) { %>
    <a href="/admin" class="sidebar-link admin-link"><i class="fas fa-shield-halved"></i> Admin Panel</a>
    <% } %>
    <a href="/logout" class="sidebar-link logout-link"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </nav>
</div>
